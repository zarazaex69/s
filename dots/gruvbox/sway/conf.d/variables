### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

# Apps
set $term foot
set $menu  j4-dmenu-desktop --dmenu='bemenu -i -l 10'
set $screenshot grimshot --notify save area $HOME/Pictures/Screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png
set $filemanager foot yazi
set $clipboard-hist cliphist list | bemenu -i -l 20| cliphist decode | wl-copy
set $web-browser firefox
set $notification sh $HOME/.config/sway/scripts/dunst-hist.sh
set $wallpaper-picker sh $HOME/.config/sway/scripts/wallpaper-picker-beta.sh
