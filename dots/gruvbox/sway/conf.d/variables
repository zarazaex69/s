### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

# Apps
set $term foot
set $menu  j4-dmenu-desktop --dmenu='fuzzel --dmenu'
set $screenshot grim -g "$(slurp)" $HOME/Pictures/Screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png
set $filemanager foot yazi
set $clipboard-hist cliphist list | fuzzel --dmenu -p "Clipboard: " | cliphist decode | wl-copy
set $web-browser firefox
set $notification sh $HOME/.config/sway/scripts/dunst-hist.sh
